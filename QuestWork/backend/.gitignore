# Maven 빌드 결과물 - 소스에서 다시 생성 가능
target/
!**/src/main/**/target/
!**/src/test/**/target/
build/
!**/src/main/**/build/
!**/src/test/**/build/
out/
/dist/
*.class

# Maven wrapper jar 바이너리
.mvn/wrapper/maven-wrapper.jar

# DB 접속 정보(username/password)가 포함된 설정 파일 - 절대 올리면 안 됨
# 대신 application.properties.example 을 참고해서 각자 작성
src/main/resources/application.properties
src/main/resources/application-*.properties
src/main/resources/application-*.yml

# HELP.md - Spring Initializr 가 생성한 안내 파일, 코드 아님
HELP.md

# IDE 설정
.idea/
.idea/workspace.xml
.idea/usage.statistics.xml
.idea/shelf/
*.iws
*.iml
*.ipr
.vscode/
.settings/
.classpath
.project
.factorypath
.springBeans
.sts4-cache
.apt_generated

# NetBeans
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/

# OS
.DS_Store
Thumbs.db

# 로그
*.log
